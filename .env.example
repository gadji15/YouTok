# Docker Compose env (this file is optional; docker-compose.yml has defaults)
COMPOSE_PROJECT_NAME=aiclip

# Production (docker-compose.prod.yml / Caddy)
DOMAIN=example.com
ACME_EMAIL=you@example.com

# Optional but recommended: protect the whole app with Caddy BasicAuth.
# Generate the hash on the server:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
BASIC_AUTH_USER=
BASIC_AUTH_HASH=

# Backend
# Ensure files created in bind-mounted ./backend are owned by your Linux user
# (prevents "Permission denied" when deleting node_modules / vendor).
DOCKER_UID=1002
DOCKER_GID=124

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=backend
DB_PASSWORD=backend
DB_ROOT_PASSWORD=root

QUEUE_CONNECTION=database

# Avoid requiring DB tables for sessions/cache on the very first run
SESSION_DRIVER=file
CACHE_STORE=file

# Admin-only access controls
# In production, you must change these defaults.
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORD=Messigadji1503
INTERNAL_API_SECRET=f82a84b5733134210ca1dddde0a19a4c7482beb3d5ab451df68c1cbce3118815
ong-random-string

# video-worker integration (optional; enable with: docker compose --profile video-worker up)
# Leave blank unless the video-worker profile is running.
VIDEO_WORKER_BASE_URL=http://video-worker-api:8000
VIDEO_WORKER_API_KEY=
VIDEOplease-chan_WORKER_CALLBACK_SECRET=4942f5d982947c01bb33bcb81c1cc4dc080a1eaf29e1cf12c482f5f5969c2ab0

WORKER_CALLBACK_URL=http://backend:8000/api/worker/callback

# shared volume used for storing worker artifacts (mounted into backend + worker containers)
SHARED_STORAGE_ROOT=/shared

# video-worker runtime (optional)
VIDEO_WORKER_REDIS_URL=redis://redis:6379/0
VIDEO_WORKER_STORAGE_PATH=/shared/video-worker
VIDEO_WORKER_WHISPER_MODEL=base
VIDEO_WORKER_WHISPER_DEVICE=auto
VIDEO_WORKER_WHISPER_TEMPERATURE=0.0
VIDEO_WORKER_WHISPER_BEAM_SIZE=1
VIDEO_WORKER_WHISPER_BEST_OF=1
VIDEO_WORKER_SUBTITLE_TEMPLATE=default

# Title generation (optional)
# - heuristic (default)
# - openai (requires VIDEO_WORKER_OPENAI_API_KEY)
VIDEO_WORKER_TITLE_PROVIDER=heuristic
VIDEO_WORKER_OPENAI_API_KEY=
VIDEO_WORKER_OPENAI_MODEL=gpt-4.1-mini
VIDEO_WORKER_OPENAI_BASE_URL=https://api.openai.com/v1

VIDEO_WORKER_TARGET_FPS=30
VIDEO_WORKER_ENABLE_LOUDNORM=false
VIDEO_WORKER_LOG_LEVEL=INFO
VIDEO_WORKER_METRICS_ENABLED=true
VIDEO_WORKER_SENTRY_DSN=
VIDEO_WORKER_SENTRY_TRACES_SAMPLE_RATE=0.0
VIDEO_WORKER_CALLBACK_HOST_ALLOWLIST=
VIDEO_WORKER_CALLBACK_MAX_RETRIES=3
VIDEO_WORKER_CALLBACK_RETRY_BACKOFF_SECONDS=0.5
VIDEO_WORKER_DOWNLOAD_MAX_RETRIES=2
VIDEO_WORKER_DOWNLOAD_RETRY_BACKOFF_SECONDS=1.0

# tiktok-bot (optional; enable with: docker compose --profile tiktok-bot up)
PUBLISH_MODE=stub
PUBLISH_REDIS_URL=redis://redis:6379/1

# Backend -> tiktok-bot integration (optional)
# If you use the optional docker-compose "tiktok-bot" profile, set:
#   TIKTOK_BOT_BASE_URL=http://tiktok-bot:3000
TIKTOK_BOT_BASE_URL=

# tiktok-bot internal calls use the same secret as the backend internal API.
# Header: X-Internal-Secret: <INTERNAL_API_SECRET>
# (tiktok-bot also supports PUBLISH_INTERNAL_SECRET, but docker-compose wires INTERNAL_API_SECRET by default.)