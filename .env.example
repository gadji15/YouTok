# Copy this file to ".env" at repo root (it is gitignored).
#
# Local defaults match docker-compose.yml.

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=backend
DB_PASSWORD=backend
DB_ROOT_PASSWORD=root

QUEUE_CONNECTION=database
SESSION_DRIVER=file
CACHE_STORE=file

# Admin-only access
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORD=password
INTERNAL_API_SECRET=change-me

# video-worker integration (optional)
VIDEO_WORKER_BASE_URL=
VIDEO_WORKER_API_KEY=
VIDEO_WORKER_CALLBACK_SECRET=change-me-too
WORKER_CALLBACK_URL=http://backend:8000/api/worker/callback

# Shared volume used for worker artifacts (mounted into backend + worker containers)
SHARED_STORAGE_ROOT=/shared

# tiktok-bot integration (optional)
TIKTOK_BOT_BASE_URL=

# Container user used for writing into the bind-mounted ./backend folder
DOCKER_UID=1000
DOCKER_GID=1000

# Production-only (docker-compose.prod.yml + Caddy)
DOMAIN=example.com
ACME_EMAIL=admin@example.com
# Optional: protect the whole app with basic auth (see Caddyfile)
BASIC_AUTH_USER=
BASIC_AUTH_HASH=
